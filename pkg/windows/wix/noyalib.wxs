<?xml version='1.0' encoding='windows-1252'?>
<!--
SPDX-FileCopyrightText: 2026 Noyalib
SPDX-License-Identifier: MIT OR Apache-2.0

WiX 3.x source for the noyalib MSI installer.

Built by `cargo wix` from the Windows leg of `release-binaries.yml`.
The pipeline rewrites __VERSION__ before invoking candle/light;
the built MSI is then signed with cosign keyless and uploaded to
the GitHub Release.

Install path: C:\Program Files\noyalib\
Adds %ProgramFiles%\noyalib to the system PATH so `noyafmt` and
`noyavalidate` work from any cmd / PowerShell prompt.
-->

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>
    <Product
        Id='*'
        Name='noyalib'
        UpgradeCode='4f2a3b6e-9c7d-4f1a-8e54-5d8c5e4b9c12'
        Manufacturer='Sebastien Rousseau'
        Version='__VERSION__'
        Language='1033'
        Codepage='1252'>

        <Package
            Id='*'
            Keywords='Installer'
            Description='noyalib — pure-Rust YAML 1.2 parser, formatter, and validator (zero unsafe)'
            Manufacturer='Sebastien Rousseau'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252' />

        <MajorUpgrade DowngradeErrorMessage='A later version of noyalib is already installed. Setup will now exit.' />

        <Media Id='1' Cabinet='cabinet.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1' />
        <Property Id='DiskPrompt' Value='noyalib __VERSION__ Installation' />

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='ProgramFiles64Folder'>
                <Directory Id='APPLICATIONROOTDIRECTORY' Name='noyalib'>
                    <Component Id='noyafmt.exe' Guid='*'>
                        <File Id='NoyafmtExe' Source='target\release\noyafmt.exe' KeyPath='yes' />
                    </Component>
                    <Component Id='noyavalidate.exe' Guid='*'>
                        <File Id='NoyavalidateExe' Source='target\release\noyavalidate.exe' KeyPath='yes' />
                    </Component>
                    <Component Id='LicenseMit' Guid='*'>
                        <File Id='LicenseMitFile' Source='LICENSE-MIT' KeyPath='yes' />
                    </Component>
                    <Component Id='LicenseApache' Guid='*'>
                        <File Id='LicenseApacheFile' Source='LICENSE-APACHE' KeyPath='yes' />
                    </Component>
                    <Component Id='Path' Guid='b3a1c4d2-7e6f-44a8-9c3e-5b1f2c4d6e8a' KeyPath='yes'>
                        <Environment
                            Id='PATH'
                            Name='PATH'
                            Value='[APPLICATIONROOTDIRECTORY]'
                            Permanent='no'
                            Part='last'
                            Action='set'
                            System='yes' />
                    </Component>
                </Directory>
            </Directory>
        </Directory>

        <Feature Id='Binaries'  Title='noyalib binaries'  Level='1' Description='noyafmt and noyavalidate executables.' AllowAdvertise='no' Display='expand'>
            <ComponentRef Id='noyafmt.exe' />
            <ComponentRef Id='noyavalidate.exe' />
            <ComponentRef Id='LicenseMit' />
            <ComponentRef Id='LicenseApache' />
            <Feature Id='Path' Title='PATH integration' Description='Add the install dir to the system PATH.' Level='1'>
                <ComponentRef Id='Path' />
            </Feature>
        </Feature>

        <!-- No ARP icon: pkg/windows/wix/noyalib.ico is not in-tree.
             Add the .ico and restore <Icon>/ARPPRODUCTICON to give the
             installer a custom Add/Remove Programs icon. -->
        <Property Id='ARPHELPLINK' Value='https://github.com/sebastienrousseau/noyalib' />
        <Property Id='ARPURLINFOABOUT' Value='https://github.com/sebastienrousseau/noyalib' />
    </Product>
</Wix>
