#!/usr/bin/make -f
# SPDX-License-Identifier: MIT OR Apache-2.0

# debian/rules — Debian source-package build rules for noyalib.
# Driven by debhelper 13 with dh-cargo for Cargo integration.
#
# Build steps:
#   1. NOYA_GEN_ASSETS=1 cargo build --release   → binaries + assets
#   2. dh_install copies binaries, man pages, completions, docs
#   3. dh_strip splits debug symbols into noyalib-dbgsym

export DH_VERBOSE = 1
export CARGO_HOME = $(CURDIR)/debian/cargo_home
export NOYA_GEN_ASSETS = 1

# Reproducible-build flags.
export RUSTFLAGS = --remap-path-prefix=$(CURDIR)=. \
                   --remap-path-prefix=$(HOME)=~

%:
	dh $@ --buildsystem=cargo

override_dh_auto_build:
	cargo build --release --locked \
	    --manifest-path crates/noya-cli/Cargo.toml \
	    --bin noyafmt --bin noyavalidate

override_dh_auto_install:
	# Binaries
	install -Dm755 target/release/noyafmt      debian/noyalib/usr/bin/noyafmt
	install -Dm755 target/release/noyavalidate debian/noyalib/usr/bin/noyavalidate
	# Man pages
	install -Dm644 doc/noyafmt.1               debian/noyalib/usr/share/man/man1/noyafmt.1
	install -Dm644 doc/noyavalidate.1          debian/noyalib/usr/share/man/man1/noyavalidate.1
	# Shell completions
	install -Dm644 complete/noyafmt.bash       debian/noyalib/usr/share/bash-completion/completions/noyafmt
	install -Dm644 complete/noyavalidate.bash  debian/noyalib/usr/share/bash-completion/completions/noyavalidate
	install -Dm644 complete/noyafmt.fish       debian/noyalib/usr/share/fish/vendor_completions.d/noyafmt.fish
	install -Dm644 complete/noyavalidate.fish  debian/noyalib/usr/share/fish/vendor_completions.d/noyavalidate.fish
	install -Dm644 complete/_noyafmt           debian/noyalib/usr/share/zsh/vendor-completions/_noyafmt
	install -Dm644 complete/_noyavalidate      debian/noyalib/usr/share/zsh/vendor-completions/_noyavalidate
	# Documentation
	install -Dm644 README.md                   debian/noyalib/usr/share/doc/noyalib/README.md
	install -Dm644 CHANGELOG.md                debian/noyalib/usr/share/doc/noyalib/CHANGELOG.md

override_dh_auto_test:
	cargo test --release --locked --workspace --no-run

override_dh_strip:
	dh_strip --dbgsym-migration='noyalib-dbgsym (<< 0.0.1-1)'
