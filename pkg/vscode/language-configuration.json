{
    "//": "VS Code language configuration for YAML — bracket pairs, comment markers, indentation rules.",
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"]
    ],
    "autoClosingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^\\s*.*[:-]\\s*$",
        "decreaseIndentPattern": "^\\s*$"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*-\\s+.*$",
            "action": { "indent": "indent" }
        }
    ]
}
