#compdef noyavalidate

autoload -U is-at-least

_noyavalidate() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-s+[Validate each document against the JSON Schema 2020-12 at PATH (the schema may itself be YAML or JSON)]:PATH:_files' \
'--schema=[Validate each document against the JSON Schema 2020-12 at PATH (the schema may itself be YAML or JSON)]:PATH:_files' \
'--fix[Rewrite FILE in place via the CST formatter (lossless\: byte-faithful for everything except normalised whitespace and line endings). With stdin input, the formatted bytes go to stdout]' \
'-q[Suppress success output]' \
'--quiet[Suppress success output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::file -- YAML file to validate. Use `-` or omit for stdin:_files' \
&& ret=0
}

(( $+functions[_noyavalidate_commands] )) ||
_noyavalidate_commands() {
    local commands; commands=()
    _describe -t commands 'noyavalidate commands' commands "$@"
}

if [ "$funcstack[1]" = "_noyavalidate" ]; then
    _noyavalidate "$@"
else
    compdef _noyavalidate noyavalidate
fi
