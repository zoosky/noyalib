#compdef noyafmt

autoload -U is-at-least

_noyafmt() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--indent=[Indentation width in spaces]:N:_default' \
'(--write)--check[Verify each FILE is formatted; print the list of files that need formatting and exit 1 if any do. Non-destructive. Suitable as a pre-commit / CI gate]' \
'--write[Rewrite each FILE in place. Default is to print the formatted source to stdout]' \
'()--stdin[Read from stdin, write to stdout. Mutually exclusive with FILE arguments]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'*::files -- YAML files to format. Pass `--stdin` to read from stdin instead:_files' \
&& ret=0
}

(( $+functions[_noyafmt_commands] )) ||
_noyafmt_commands() {
    local commands; commands=()
    _describe -t commands 'noyafmt commands' commands "$@"
}

if [ "$funcstack[1]" = "_noyafmt" ]; then
    _noyafmt "$@"
else
    compdef _noyafmt noyafmt
fi
